{
  "name": "meritbooks",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "db:migrate": "cd packages/supabase && supabase db push",
    "db:seed": "cd packages/supabase && npx tsx seed/index.ts",
    "db:reset": "cd packages/supabase && supabase db reset",
    "db:types": "cd packages/supabase && supabase gen types typescript --local > types/database.ts"
  },
  "devDependencies": {
    "dotenv": "^17.4.1",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "npm@10.8.0",
  "engines": {
    "node": ">=20"
  }
}
